NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNramRqbnhremlobXNrc29qamNiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzODA4MTcsImV4cCI6MjA5Nzk1NjgxN30.6YULyX_nCplQL7e0J-mOWm5NbiKOYlj92xAnkjOPtZI

# Server-only — never exposed to the browser. Used for privileged operations
# (e.g. service-role admin tasks). Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Used to build absolute redirect URLs for OAuth callbacks.
# e.g. http://localhost:3000 in dev, https://nexhub.app in prod
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth — configured in Google Cloud Console, then registered as a
# provider in Supabase Auth (Authentication > Providers > Google).
# These two are NOT read directly by the Next.js app — Supabase Auth holds
# them server-side — but are documented here so the whole auth setup lives
# in one place.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
